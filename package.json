{
  "name": "unplugin-svelte-comps",
  "version": "0.1.0",
  "description": "On-demand Svelte 5 components auto-importing",
  "keywords": [
    "esbuild",
    "rolldown",
    "rollup",
    "rspack",
    "svelte",
    "unplugin",
    "vite"
  ],
  "homepage": "https://github.com/utakotoba/unplugin-svelte-comps#readme",
  "bugs": {
    "url": "https://github.com/utakotoba/unplugin-svelte-comps/issues"
  },
  "license": "MIT",
  "author": "Ly <i@letter.cafe>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/utakotoba/unplugin-svelte-comps.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*.d.mts",
        "./*"
      ]
    }
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./esbuild": "./dist/esbuild.mjs",
    "./rolldown": "./dist/rolldown.mjs",
    "./rollup": "./dist/rollup.mjs",
    "./rspack": "./dist/rspack.mjs",
    "./types": "./dist/types.mjs",
    "./vite": "./dist/vite.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "fmt": "oxfmt",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "build": "tsdown"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "magic-string": "^0.30.21",
    "tinyglobby": "^0.2.16",
    "unplugin": "^3.0.0"
  },
  "devDependencies": {
    "@rspack/core": "^2.0.3",
    "@types/bun": "^1.3.14",
    "@types/estree": "^1.0.9",
    "@typescript/native-preview": "^7.0.0-dev.20260514.1",
    "esbuild": "^0.28.0",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "rolldown": "^1.0.1",
    "rollup": "^4.60.4",
    "svelte": "^5.55.7",
    "tsdown": "^0.22.0",
    "vite": "^8.0.13"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "packageManager": "bun@1.3.14"
}
