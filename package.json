{
  "name": "unplugin-svelte-comps",
  "version": "0.1.0",
  "description": "On-demand Svelte 5 components auto-importing",
  "keywords": [
    "rolldown",
    "rollup",
    "svelte",
    "unplugin",
    "vite",
    "webpack"
  ],
  "homepage": "https://github.com/utakotoba/unplugin-svelte-comps#readme",
  "bugs": {
    "url": "https://github.com/utakotoba/unplugin-svelte-comps/issues"
  },
  "license": "MIT",
  "author": "Ly <i@letter.cafe>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/utakotoba/unplugin-svelte-comps.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*.d.mts",
        "./*"
      ]
    }
  },
  "exports": {
    ".": "./dist/index.mjs"
  },
  "scripts": {
    "fmt": "oxfmt",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "build": "tsdown"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@typescript/native-preview": "^7.0.0-dev.20260514.1",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "tsdown": "^0.22.0"
  },
  "packageManager": "bun@1.3.14"
}
